# ============================================
# UPTEND - Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your values
# Run `npm run setup` to validate your configuration

# ============================================
# 🔴 REQUIRED - App will not start without these
# ============================================

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:password@localhost:5432/uptend
DATABASE_URL=

# Secret key for session encryption (generate with: openssl rand -base64 32)
SESSION_SECRET=


# ============================================
# 🟠 CRITICAL - Choose ONE Stripe configuration
# ============================================

# --- Option 1: Replit-Managed Stripe (recommended for Replit deployments) ---
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
# WEB_REPL_RENEWAL=

# --- Option 2: Direct Stripe Integration (for local/production) ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=


# ============================================
# 🟠 CRITICAL - AI Features
# ============================================

# Anthropic API key for AI Concierge, Photo Analysis, Document Scanner, etc.
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key for chatbot and additional AI features:
# - Photo analysis & volume estimation
# - AI triage & categorization
# - Sentiment analysis (Revenue Protector)
# - Pre-damage detection (Conflict Shield)
# - Smart dispatch recommendations
# - Home inventory AI
# - Rebate receipt validation
# - Hazard detection
# Get your key from: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=

# Optional: Custom OpenAI base URL (leave empty for default)
# AI_INTEGRATIONS_OPENAI_BASE_URL=


# ============================================
# 🟠 CRITICAL - Google APIs
# ============================================

# Google Places API key for address autocomplete
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Geocoding API
GOOGLE_PLACES_API_KEY=


# ============================================
# 🟠 CRITICAL - Property Data (RapidAPI)
# ============================================

# RapidAPI key for Home Listing US - accurate property valuations
# Get your key from: https://rapidapi.com/
# Subscribe to: Home Listing US API
# Without this key, property values will use free Census estimates (less accurate)
RAPIDAPI_KEY=


# ============================================
# 🟠 CRITICAL - Replit Authentication
# ============================================

# Required for Replit OAuth authentication
# Get this from your Repl's environment
REPL_ID=

# Optional: OpenID Connect issuer URL (defaults to https://replit.com/oidc)
# ISSUER_URL=https://replit.com/oidc


# ============================================
# 🟡 OPTIONAL - Email Notifications (SendGrid)
# ============================================

# SendGrid API key for transactional emails
# Get your key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=

# Sender email address for outgoing emails
# FROM_EMAIL=noreply@uptend.app


# ============================================
# 🟡 OPTIONAL - SMS Notifications (Twilio)
# ============================================

# Twilio credentials for SMS alerts
# Get these from: https://console.twilio.com/
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=


# ============================================
# 🟡 OPTIONAL - Admin Configuration
# ============================================

# Admin dashboard credentials
# ADMIN_PASSWORD=

# Admin contact for critical alerts
# ADMIN_EMAIL=admin@uptend.app
# ADMIN_PHONE=+14073383342


# ============================================
# 🟡 OPTIONAL - External API Integration
# ============================================

# API key for external agent integrations
# AGENT_API_KEY=


# ============================================
# 🟡 OPTIONAL - Deployment Configuration
# ============================================

# Environment mode (development or production)
NODE_ENV=development

# Server port (defaults to 5000)
# PORT=5000

# Replit deployment variables (auto-populated on Replit)
# REPLIT_DOMAINS=
# REPLIT_DEV_DOMAIN=
# REPL_SLUG=
# REPL_OWNER=
# REPLIT_DEPLOYMENT=


# ============================================
# 🟡 OPTIONAL - Object Storage
# ============================================

# File storage configuration (for Replit object storage)
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=


# ============================================
# 🟡 OPTIONAL - Business Logic
# ============================================

# Insurance handling mode (defaults to BLANKET_ARBITRAGE)
# Options: BLANKET_ARBITRAGE, PER_JOB, NONE
# INSURANCE_MODE=BLANKET_ARBITRAGE


# ============================================
# 🟡 OPTIONAL - AWS S3 Storage
# ============================================

# AWS credentials for S3 file uploads (photos, documents)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============================================
# 🟡 OPTIONAL - Together AI
# ============================================

# Together AI API key (alternative AI provider)
# TOGETHER_API_KEY=

# ============================================
# 🟡 OPTIONAL - Background Checks
# ============================================

# Checkr API key for pro background verification
# CHECKR_API_KEY=

# ============================================
# 🟡 OPTIONAL - Smart Home Integrations
# ============================================

# Smart home device API credentials
# NEST_CLIENT_ID=
# NEST_CLIENT_SECRET=
# ECOBEE_CLIENT_ID=
# ECOBEE_CLIENT_SECRET=
# AUGUST_CLIENT_ID=
# AUGUST_CLIENT_SECRET=
# RING_CLIENT_ID=
# RING_CLIENT_SECRET=
# MYQ_CLIENT_ID=
# MYQ_CLIENT_SECRET=

# ============================================
# 🟡 OPTIONAL - Google OAuth & Calendar
# ============================================

# Google OAuth (for social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=

# Google Calendar integration
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=

# ============================================
# 🟡 OPTIONAL - ElevenLabs TTS
# ============================================

# ElevenLabs API key for George AI voice
# ELEVENLABS_API_KEY=

# ============================================
# 🟡 OPTIONAL - Job Management Integrations
# ============================================

# Jobber integration
# JOBBER_CLIENT_ID=
# JOBBER_CLIENT_SECRET=

# QuickBooks integration
# QB_CLIENT_ID=
# QB_CLIENT_SECRET=
# QB_REDIRECT_URI=

# Gusto payroll integration
# GUSTO_CLIENT_ID=
# GUSTO_CLIENT_SECRET=

# ============================================
# 🟡 OPTIONAL - Insurance Partners
# ============================================

# Next Insurance partner integration
# NEXT_INSURANCE_PARTNER_ID=
# THIMBLE_API_KEY=
# THIMBLE_PARTNER_ID=

# ============================================
# 🟡 OPTIONAL - Search & Web
# ============================================

# Brave Search API
# BRAVE_API_KEY=

# Google Custom Search
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_CX=

# SAM.gov API (government contracts)
# SAM_GOV_API_KEY=

# ============================================
# 🟡 OPTIONAL - Security
# ============================================

# JWT secret for API tokens
# JWT_SECRET=

# Encryption key for integration credentials
# INTEGRATION_ENCRYPTION_KEY=

# Cron job API key
# CRON_API_KEY=

# Admin API key
# ADMIN_KEY=

# ============================================
# 🟡 OPTIONAL - Database Tuning
# ============================================

# Database connection pool size (default: 10)
# DB_POOL_SIZE=10

# Log level (debug, info, warn, error)
# LOG_LEVEL=info

# ============================================
# 📝 NOTES
# ============================================
#
# Minimum viable configuration for local development:
#   1. DATABASE_URL (PostgreSQL database)
#   2. SESSION_SECRET (random string)
#   3. STRIPE_SECRET_KEY + STRIPE_PUBLISHABLE_KEY (test keys)
#   4. AI_INTEGRATIONS_OPENAI_API_KEY (OpenAI key)
#
# To get started quickly:
#   - Use local PostgreSQL: postgresql://postgres:password@localhost:5432/uptend
#   - Generate SESSION_SECRET: openssl rand -base64 32
#   - Get Stripe test keys: https://dashboard.stripe.com/test/apikeys
#   - Get OpenAI key: https://platform.openai.com/api-keys
#
# Run `npm run setup` to validate your configuration
